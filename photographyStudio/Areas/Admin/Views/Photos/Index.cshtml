@model IEnumerable<KxnPhotoStudio.Models.Photo>

@{
    ViewData["Title"] = "Manage Photos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Photos</h1>
    <a asp-action="Create" class="btn btn-dark">Upload Photo</a>
</div>

<table class="table table-bordered table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>Preview</th>
            <th>Title</th>
            <th>Category</th>
            <th>Created</th>
            <th style="width: 180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var photo in Model)
        {
            <tr>
                <td>
                    <img src="@photo.ImagePath" alt="@photo.Title" style="width:100px; height:70px; object-fit:cover;" />
                </td>
                <td>@photo.Title</td>
                <td>@photo.Category?.Name</td>
                <td>@photo.CreatedDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@photo.PhotoId" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@photo.PhotoId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>